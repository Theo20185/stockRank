{
  "name": "stockrank",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -b",
    "build": "npm run build --workspaces --if-present",
    "ingest": "npm run ingest --workspace=@stockrank/data",
    "refresh": "tsx scripts/refresh.ts",
    "refresh-all": "tsx scripts/refresh-all.ts",
    "screenshot": "tsx scripts/screenshot.ts",
    "backtest": "tsx scripts/backtest.ts",
    "fv-trend": "tsx scripts/compute-fv-trend.ts"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "playwright": "^1.59.1",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "vitest": "^3.0.0"
  }
}
